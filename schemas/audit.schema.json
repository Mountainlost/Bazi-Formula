{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BaziAudit",
  "description": "Audit output for file boundaries, evidence registry, candidate wording, and controlled final useful god consistency.",
  "type": "object",
  "required": [
    "audit_version",
    "engine_version",
    "rules_version",
    "report_version",
    "passed",
    "checks"
  ],
  "properties": {
    "audit_version": { "type": "string" },
    "engine_version": { "type": "string" },
    "rules_version": { "type": "string" },
    "report_version": { "type": "string" },
    "passed": { "type": "boolean" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "passed", "message"],
        "properties": {
          "name": { "type": "string" },
          "passed": { "type": "boolean" },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
