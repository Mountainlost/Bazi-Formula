{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BaziChart",
  "description": "Deterministic chart output with real four pillars and luck cycle skeleton.",
  "type": "object",
  "required": [
    "engine_version",
    "school",
    "calc_basis",
    "input_snapshot",
    "solar_datetime",
    "pillars",
    "day_master",
    "luck_cycle",
    "status"
  ],
  "properties": {
    "engine_version": {
      "type": "string"
    },
    "school": {
      "type": "string"
    },
    "calc_basis": {
      "type": "object",
      "required": [
        "calendar_type",
        "timezone",
        "true_solar_time",
        "real_calendar",
        "month_rule",
        "day_rule",
        "library_name"
      ],
      "properties": {
        "calendar_type": {
          "type": "string",
          "enum": ["solar"]
        },
        "timezone": {
          "type": "string"
        },
        "true_solar_time": {
          "type": "boolean"
        },
        "real_calendar": {
          "type": "boolean",
          "enum": [true]
        },
        "month_rule": {
          "type": "string"
        },
        "day_rule": {
          "type": "string"
        },
        "library_name": {
          "type": "string"
        },
        "normalization_steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/calcNormalizationStep"
          }
        }
      },
      "additionalProperties": false
    },
    "input_snapshot": {
      "type": "object",
      "required": [
        "birth_date",
        "birth_time",
        "birth_place",
        "gender",
        "calendar_type",
        "timezone",
        "true_solar_time",
        "school"
      ],
      "properties": {
        "birth_date": {
          "type": "string"
        },
        "birth_time": {
          "type": "string"
        },
        "birth_place": {
          "type": "string"
        },
        "gender": {
          "type": "string"
        },
        "calendar_type": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "true_solar_time": {
          "type": "boolean"
        },
        "school": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "solar_datetime": {
      "type": "string"
    },
    "pillars": {
      "type": "object",
      "required": ["year", "month", "day", "hour"],
      "properties": {
        "year": {
          "$ref": "#/$defs/ganzhiPillar"
        },
        "month": {
          "$ref": "#/$defs/ganzhiPillar"
        },
        "day": {
          "$ref": "#/$defs/ganzhiPillar"
        },
        "hour": {
          "$ref": "#/$defs/ganzhiPillar"
        }
      },
      "additionalProperties": false
    },
    "day_master": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1
    },
    "luck_cycle": {
      "$ref": "#/$defs/luckCycle"
    },
    "status": {
      "type": "string",
      "enum": ["ok"]
    }
  },
  "$defs": {
    "ganzhiPillar": {
      "type": "object",
      "required": ["stem", "branch", "ganzhi"],
      "properties": {
        "stem": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1
        },
        "ganzhi": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2
        }
      },
      "additionalProperties": false
    },
    "calcNormalizationStep": {
      "type": "object",
      "required": ["name", "input_value", "output_value", "evidence_refs"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["lunar_to_solar", "true_solar_time_adjustment"]
        },
        "input_value": {
          "type": "string"
        },
        "output_value": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "luckCycleBasis": {
      "type": "object",
      "required": [
        "direction_rule",
        "start_age_rule",
        "jieqi_anchor_rule",
        "library_name",
        "enabled"
      ],
      "properties": {
        "direction_rule": {"type": "string"},
        "start_age_rule": {"type": "string"},
        "jieqi_anchor_rule": {"type": "string"},
        "library_name": {"type": "string"},
        "enabled": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "luckCycleEntry": {
      "type": "object",
      "required": [
        "index",
        "ganzhi",
        "stem",
        "branch",
        "start_age",
        "end_age",
        "start_year",
        "end_year",
        "evidence_refs"
      ],
      "properties": {
        "index": {"type": "integer", "minimum": 1},
        "ganzhi": {"type": "string", "minLength": 2, "maxLength": 2},
        "stem": {"type": "string", "minLength": 1, "maxLength": 1},
        "branch": {"type": "string", "minLength": 1, "maxLength": 1},
        "start_age": {"type": "number"},
        "end_age": {"type": "number"},
        "start_year": {"type": "integer"},
        "end_year": {"type": "integer"},
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "luckCycle": {
      "type": "object",
      "required": [
        "basis",
        "direction",
        "start_age",
        "start_datetime",
        "cycles",
        "evidence_refs"
      ],
      "properties": {
        "basis": {"$ref": "#/$defs/luckCycleBasis"},
        "direction": {"type": "string", "enum": ["forward", "backward"]},
        "start_age": {"type": "number"},
        "start_datetime": {"type": "string"},
        "cycles": {
          "type": "array",
          "minItems": 8,
          "items": {"$ref": "#/$defs/luckCycleEntry"}
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
